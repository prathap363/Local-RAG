# Copy this file to .env and edit values for your machine.

# On Windows with Docker Desktop, use forward slashes in host paths.
# Example: C:/Users/pmohansundar/Documents/my-rag-docs
HOST_DOCS_PATH=./sample_docs

POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass

COLLECTION_NAME=local_docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
RESET_COLLECTION_ON_START=true

# Docker Desktop Model Runner OpenAI-compatible endpoint.
# Adjust if your local endpoint differs.
MODEL_RUNNER_BASE_URL=http://host.docker.internal:12434/engines/llama.cpp/v1/
MODEL_RUNNER_API_KEY=dummy

# Use model names available in your local model runner.
EMBEDDING_MODEL=all-minilm-l6-v2-vllm
QUERY_MODEL=llama3.2:1B-Q8_0
ANSWER_MODEL=llama3.2:1B-Q8_0

CORS_ALLOW_ORIGINS=*
